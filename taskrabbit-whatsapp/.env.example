# Server Configuration
PORT=3000
NODE_ENV=development

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://yourdomain.com/webhook/whatsapp

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# MercadoPago (Alternativa para LATAM)
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_token_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017/taskrabbit-whatsapp
MONGODB_URI_PROD=mongodb+srv://user:pass@cluster.mongodb.net/taskrabbit

# Redis (Para caché y sesiones)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
JWT_SECRET=your_super_secret_jwt_key_here
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Webhook Verification
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token_123

# Application Settings
DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50
SERVICE_FEE_PERCENTAGE=15
EMERGENCY_PRICE_MULTIPLIER=1.5
DEPOSIT_AMOUNT=20
